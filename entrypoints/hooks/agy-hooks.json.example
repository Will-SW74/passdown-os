{
  "_comment": "passdown-os hooks — Google Antigravity (agy) 用。放到 <專案根目錄>/.agents/hooks.json（全域版在 ~/.gemini/antigravity-cli/hooks.json）。schema 依 2026-07-12 查證的社群文件：頂層為 hook 群組名稱，事件有 PreInvocation / PostInvocation / PreToolUse / PostToolUse / Stop；hook 輸出可透過 additionalContext 併入 agent 的 prompt。【未確認】PreInvocation 的純文字 stdout 是否等同注入 context——安裝前請對照官方 hooks 文件實測驗證，並更新本檔的查證日期。",
  "passdown-os": {
    "PreInvocation": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "printf '0' > passdown-os/sessions/.toolcount 2>/dev/null; echo '=== passdown-os 交接內容 ==='; cat passdown-os/handoff/CURRENT.md 2>/dev/null || echo '（警告：找不到 passdown-os/handoff/CURRENT.md）'",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "sh passdown-os/entrypoints/hooks/checkpoint-counter.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
