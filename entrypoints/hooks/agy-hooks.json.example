{
  "_comment": "passdown-os hooks — Google Antigravity (agy) 用。放到 <專案根目錄>/.agents/hooks.json（全域版在 ~/.gemini/antigravity-cli/hooks.json）。schema 依 2026-07-12 查證的社群文件：頂層為 hook 群組名稱，事件有 PreInvocation / PostInvocation / PreToolUse / PostToolUse / Stop；已確認：PreInvocation 必須透過 stdout 輸出 JSON 格式的 additionalContext 欄位才能被 agent 注入，故採用 python 指令輸出 JSON。另注意：計數器不能在 PreInvocation 中歸零（否則每回合模型呼叫都會重置），應由開始協定與結束協定控制計數檔生命週期（已移除計數器重置指令）。",
  "passdown-os": {
    "PreInvocation": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os, json; f='passdown-os/handoff/CURRENT.md'; print(json.dumps({'additionalContext': '=== passdown-os 交接內容 ===\\n' + open(f, encoding='utf-8').read() if os.path.exists(f) else '（警告：找不到 passdown-os/handoff/CURRENT.md）'}))\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "sh passdown-os/entrypoints/hooks/checkpoint-counter.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
