{
  "description": "Passdown OS hooks for OpenAI Codex CLI. Project trust and exact hook-definition trust are separate; review changed hooks with /hooks. Windows uses commandWindows to run the same POSIX scripts through Git Bash.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$(git rev-parse --show-toplevel)/passdown-os/entrypoints/hooks/session-start.sh\" --agent codex --new-log",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& (Join-Path ((& git.exe rev-parse --show-toplevel).Trim()) 'passdown-os/entrypoints/hooks/run-posix-hook.ps1') -ScriptRelativePath 'passdown-os/entrypoints/hooks/session-start.sh' -ScriptArguments '--agent','codex','--new-log'\"",
            "timeout": 10,
            "statusMessage": "注入 passdown-os 交接內容並預建 session log"
          }
        ]
      },
      {
        "matcher": "resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"$(git rev-parse --show-toplevel)/passdown-os/entrypoints/hooks/session-start.sh\" --agent codex",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& (Join-Path ((& git.exe rev-parse --show-toplevel).Trim()) 'passdown-os/entrypoints/hooks/run-posix-hook.ps1') -ScriptRelativePath 'passdown-os/entrypoints/hooks/session-start.sh' -ScriptArguments '--agent','codex'\"",
            "timeout": 10,
            "statusMessage": "注入 passdown-os 交接內容"
          }
        ]
      }
    ],
  }
}
