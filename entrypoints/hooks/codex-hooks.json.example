{
  "_comment": "passdown-os hooks — OpenAI Codex CLI 用。放到 <專案根目錄>/.codex/hooks.json（或合併進 .codex/config.toml 的 [hooks] 表）。Codex 會要求先信任 (trust) 非受管 hook 才執行。schema 依 2026-07-12 查證的官方文件：SessionStart 的 stdout 會作為 developer context 注入模型；PostToolUse 需用 additionalContext 注入。安裝前請對照 https://developers.openai.com/codex/hooks 驗證欄位是否有變。",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "printf '0' > passdown-os/sessions/.toolcount 2>/dev/null; echo '=== passdown-os 交接內容（SessionStart hook 自動注入）==='; cat passdown-os/handoff/CURRENT.md 2>/dev/null || echo '（警告：找不到 passdown-os/handoff/CURRENT.md，請檢查框架是否就位）'; echo '--- 以上即 CURRENT.md 全文；請依 passdown-os/CONSTITUTION.md 執行 Session 開始協定其餘步驟。'",
            "timeout": 10,
            "statusMessage": "注入 passdown-os 交接內容"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "sh passdown-os/entrypoints/hooks/checkpoint-counter.sh",
            "timeout": 5,
            "statusMessage": "passdown-os 檢查點計數"
          }
        ]
      }
    ]
  }
}
