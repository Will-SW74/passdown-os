{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== passdown-os 交接內容（SessionStart hook 自動注入）==='; cat \"$CLAUDE_PROJECT_DIR/passdown-os/handoff/CURRENT.md\" 2>/dev/null || echo '（警告：找不到 passdown-os/handoff/CURRENT.md，請檢查框架是否就位）'; echo '--- 以上即 CURRENT.md 全文，Session 開始協定的「讀 CURRENT.md」步驟視為已完成；請依 passdown-os/CONSTITUTION.md 執行其餘步驟（含檢查與掛上會話鎖）。'",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "echo '【passdown-os】context 即將被壓縮：若尚未完成 Session 結束協定（覆寫 CURRENT.md、寫 session log、本機記憶同步），壓縮後細節將遺失——請先完成再壓縮。'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
