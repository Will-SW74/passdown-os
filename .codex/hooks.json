{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "printf '0' > sessions/.toolcount 2>/dev/null; echo '=== passdown-os 交接內容（SessionStart hook）==='; cat handoff/CURRENT.md 2>/dev/null || echo '（警告：找不到 handoff/CURRENT.md）'; echo '--- 以上即 CURRENT.md 全文；請依 CONSTITUTION.md 執行 Session 開始協定其餘步驟。'",
            "commandWindows": "python entrypoints/hooks/codex-windows-hook.py session-start --root .",
            "timeout": 10,
            "statusMessage": "載入 Passdown OS 交接內容"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "sh entrypoints/hooks/checkpoint-counter.sh --json",
            "commandWindows": "python entrypoints/hooks/codex-windows-hook.py checkpoint --root .",
            "timeout": 5,
            "statusMessage": "Passdown OS 檢查點計數"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 entrypoints/hooks/archive-codex-transcript.py",
            "commandWindows": "python entrypoints/hooks/archive-codex-transcript.py",
            "timeout": 30,
            "statusMessage": "保存 Codex 逐字稿快照"
          }
        ]
      }
    ]
  }
}
